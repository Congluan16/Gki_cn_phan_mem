CREATE DATABASE dating_app;
USE dating_app;

-- 1. Bảng User: Lưu thông tin tài khoản và profile cơ bản
CREATE TABLE Users (
    id_user INT AUTO_INCREMENT PRIMARY KEY,
    email VARCHAR(255) UNIQUE NOT NULL,
    password_hash VARCHAR(255) NOT NULL, -- Bảo mật theo NFR2
    full_name VARCHAR(100),
    birth_date DATE,
    gender ENUM('Male', 'Female', 'Other'),
    profile_img_id INT, -- ID ảnh đại diện trỏ sang bảng up_Img
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- 2. Bảng Hobbies: Sở thích người dùng
CREATE TABLE Hobbies (
    id_hobbies INT AUTO_INCREMENT PRIMARY KEY,
    id_user INT,
    content_hobbies TEXT,
    FOREIGN KEY (id_user) REFERENCES Users(id_user) ON DELETE CASCADE
);

-- 3. Bảng up_Img: Quản lý tất cả ảnh người dùng tải lên
CREATE TABLE up_Img (
    id_img INT AUTO_INCREMENT PRIMARY KEY,
    id_user INT,
    img_url VARCHAR(255) NOT NULL,
    is_avatar BOOLEAN DEFAULT FALSE, -- Để xác định ảnh đại diện
    time_upimg TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_user) REFERENCES Users(id_user) ON DELETE CASCADE
);

-- 4. Bảng Location: Vị trí người dùng
CREATE TABLE Location (
    id_location INT AUTO_INCREMENT PRIMARY KEY,
    id_user INT,
    country VARCHAR(100),
    city VARCHAR(100),
    ward VARCHAR(100),
    district VARCHAR(100),
    FOREIGN KEY (id_user) REFERENCES Users(id_user) ON DELETE CASCADE
);

-- 5. Bảng Matches: Cần thiết để thực hiện logic Match (Bổ sung để chạy được app)
CREATE TABLE Matches (
    id_match INT AUTO_INCREMENT PRIMARY KEY,
    user_one_id INT,
    user_two_id INT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (user_one_id) REFERENCES Users(id_user),
    FOREIGN KEY (user_two_id) REFERENCES Users(id_user)
);

-- 6. Bảng Messages: Nội dung trò chuyện giữa các cặp Match
CREATE TABLE Messages (
    id_message INT AUTO_INCREMENT PRIMARY KEY,
    id_match INT,
    sender_id INT,
    content TEXT NOT NULL,
    is_read BOOLEAN DEFAULT FALSE,
    timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_match) REFERENCES Matches(id_match) ON DELETE CASCADE,
    FOREIGN KEY (sender_id) REFERENCES Users(id_user)
);

-- 7. Bảng Note: Ghi chú cá nhân hoặc trạng thái
CREATE TABLE Notes (
    id_note INT AUTO_INCREMENT PRIMARY KEY,
    id_user INT,
    content TEXT,
    time_note TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
    FOREIGN KEY (id_user) REFERENCES Users(id_user) ON DELETE CASCADE
);